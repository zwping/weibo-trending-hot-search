{
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-write --allow-env main.ts",
    "release": "deno run --allow-net --allow-read --allow-env release.ts",
    "test": "deno test --allow-net --allow-read --allow-write"
  },
  "imports": {
    "std/": "https://deno.land/std@0.79.0/"
  },
  "fmt": {
    "lineWidth": 120
  },
  "lock": false
}
